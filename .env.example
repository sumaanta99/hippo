OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small
DATABASE_PATH=hippo.db
SQLITE_DB_PATH=./hippo.db
LOG_LEVEL=WARNING
STRUCTURED_LOGGING=false
TIMEOUT_SECONDS=10
LLM_TIMEOUT_SECONDS=10

# Production
HOST=0.0.0.0
PORT=8000
RELOAD=false
HIPPO_ENV=development
HIPPO_CORS_ORIGINS=https://your-studio-domain.com
HIPPO_SESSION_SECRET=your-random-session-secret-here
ANALYTICS_ADMIN_KEY=your-random-secret-here

# WhatsApp (Meta Cloud API recommended — set WHATSAPP_PROVIDER=twilio for Twilio)
WHATSAPP_PROVIDER=meta
WHATSAPP_WEBHOOK_SECRET=your-meta-app-secret-or-verify-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
# Twilio only:
TWILIO_ACCOUNT_SID=your-twilio-account-sid
WHATSAPP_STUDIO_URL=https://hippostudio.netlify.app
